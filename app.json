{
  "expo": {
    "name": "AppForge",
    "slug": "appforge-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "appforge",
    "splash": {
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appforge.app",
      "associatedDomains": [
        "applinks:appforge.dev"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "package": "com.appforge.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "appforge.dev",
              "pathPrefix": "/shares/"
            },
            {
              "scheme": "https",
              "host": "appforge.dev",
              "pathPrefix": "/reviews/"
            },
            {
              "scheme": "https",
              "host": "appforge.dev",
              "pathPrefix": "/web/shares/"
            },
            {
              "scheme": "https",
              "host": "appforge.dev",
              "pathPrefix": "/web/reviews/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
