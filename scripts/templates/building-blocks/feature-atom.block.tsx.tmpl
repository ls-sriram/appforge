// {{FEATURE}}-{{ATOM}}.block — leaf UI atom.
// Styling via tokens only. No children slots. No hooks except useTheme/useViewport.
// If it needs children or complex composition, it should be a .surface instead.

import React from "react";
import { StyleSheet } from "react-native";
import { Text } from "../../../../ui/primitives/Text";
import { useTheme } from "../../../../theme/ThemeProvider";

interface {{PASCAL_FEATURE}}{{PASCAL_ATOM}}BlockProps {
  value: string;
}

export function {{PASCAL_FEATURE}}{{PASCAL_ATOM}}Block({ value }: {{PASCAL_FEATURE}}{{PASCAL_ATOM}}BlockProps) {
  const t = useTheme();

  return (
    <Text style={[s.root, { color: t.colors.textPrimary }]}>{value}</Text>
  );
}

const s = StyleSheet.create({
  root: { fontSize: 14 },
});
