// {{FEATURE}}-content.layout — structural layout only.
// Calls useViewport() internally. No visual styling (no colors, no borders).
// Accepts named slots as ReactNode props. No isDesktop prop ever.

import React from "react";
import { ScrollView, StyleSheet, View } from "react-native";
import { useViewport } from "../../../../theme/Viewport";

interface {{PASCAL_FEATURE}}ContentLayoutProps {
  main: React.ReactNode;
  side?: React.ReactNode;
}

export function {{PASCAL_FEATURE}}ContentLayout({ main, side }: {{PASCAL_FEATURE}}ContentLayoutProps) {
  const { isDesktop } = useViewport();

  if (isDesktop) {
    return (
      <ScrollView style={s.scroll} contentContainerStyle={s.desktopBody} showsVerticalScrollIndicator={false}>
        <View style={s.main}>{main}</View>
        {side ? <View style={s.side}>{side}</View> : null}
      </ScrollView>
    );
  }

  return (
    <ScrollView style={s.scroll} contentContainerStyle={s.mobileBody} showsVerticalScrollIndicator={false}>
      <View style={s.mobileSection}>{main}</View>
      <View style={s.bottomSpacer} />
    </ScrollView>
  );
}

const s = StyleSheet.create({
  scroll: { flex: 1 },
  desktopBody: { flexDirection: "row", padding: 32, gap: 36, minHeight: "100%" },
  main: { flex: 1 },
  side: { width: 320, flexShrink: 0 },
  mobileBody: { paddingBottom: 16 },
  mobileSection: { paddingHorizontal: 16, paddingTop: 14 },
  bottomSpacer: { height: 8 },
});
