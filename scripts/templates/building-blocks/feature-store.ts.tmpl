function subscribe(listener: Listener) {
  listeners.add(listener);
  return () => listeners.delete(listener);
}

export function use{{PASCAL_FEATURE}}Store(): {{PASCAL_FEATURE}}StoreState {
  return useSyncExternalStore(subscribe, {{camel_FEATURE}}StoreGetState, {{camel_FEATURE}}StoreGetState);
