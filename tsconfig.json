{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@theme/*": [
        "src/platform/theme/*"
      ],
      "@core/*": [
        "src/platform/core/*"
      ],
      "@api/*": [
        "src/platform/api/*"
      ],
      "@providers/*": [
        "src/platform/providers/*"
      ],
      "@navigation/*": [
        "src/platform/navigation/*"
      ],
      "@primitives/*": [
        "src/platform/ui/primitives/*"
      ],
      "@layouts": [
        "src/platform/ui/layouts/index.ts"
      ],
      "@layouts/*": [
        "src/platform/ui/layouts/*"
      ],
      "@surfaces/*": [
        "src/platform/ui/primitives/*"
      ],
      "@scaffolds/*": [
        "src/platform/ui/scaffolds/*"
      ],
      "@components/*": [
        "src/platform/ui/components/*"
      ],
      "@panels/*": [
        "src/platform/ui/panels/*"
      ],
      "@blocks/*": [
        "src/platform/ui/blocks/*"
      ],
      "@ui": [
        "src/platform/ui/index.ts"
      ],
      "@ui/*": [
        "src/platform/ui/*"
      ],
      "@features/*": [
        "src/features/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build"
  ],
  "extends": "expo/tsconfig.base"
}
