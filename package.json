{
  "name": "appforge",
  "version": "0.1.0",
  "description": "Single-command scaffolding for web, mobile, and desktop apps with shared UI, backend integration, and optional Electron DMG packaging.",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "save-server": "node scripts/save-server.mjs",
    "clean": "node scripts/clean.mjs",
    "start": "./scripts/start-selected-expo.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "./scripts/start-selected-expo.sh --web",
    "desktop:clean": "node scripts/desktop/clean.mjs",
    "desktop:build:web": "node scripts/desktop/prepare-web-build.mjs",
    "desktop:dmg": "node scripts/desktop/package-dmg.mjs",
    "desktop:build:web:appforge": "APP_ID=appforge-site node scripts/desktop/prepare-web-build.mjs appforge-site",
    "desktop:dmg:appforge": "APP_ID=appforge-site node scripts/desktop/package-dmg.mjs appforge-site",
    "local:frontend": "./scripts/dev/run-frontend.sh",
    "local:backend": "./scripts/dev/run-backend.sh",
    "local:verify": "./scripts/dev/verify-runtime-integrations.sh",
    "local:start": "./scripts/dev/run-local.sh",
    "local:stop": "./scripts/dev/stop-local.sh",
    "db:dashboard": "node tools/db-dashboard/generate-report.mjs",
    "db:early-access:approve": "node tools/db-dashboard/toggle-early-access.mjs --status approved",
    "db:early-access:waitlist": "node tools/db-dashboard/toggle-early-access.mjs --status waitlist",
    "typecheck": "tsc --noEmit",
    "lint:arch": "node scripts/check-layer-boundaries.js",
    "test": "jest --watchman=false",
    "test:usecases": "jest --watchman=false --testPathPattern=\"src/features/.*/usecases/__tests__/.*\\.test\\.ts$\"",
    "test:viewmodel": "jest --watchman=false --testPathPattern=\"src/features/.*/viewmodel/__tests__/.*\\.test\\.ts$\"",
    "test:controllers": "jest --watchman=false --testPathPattern=\"src/features/.*/__tests__/.*controller.*\\.test\\.ts$\"",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth": "playwright test e2e/auth.spec.ts",
    "test:e2e:settings": "playwright test e2e/settings-auth.spec.ts",
    "api:generate": "tsx scripts/generate-api.ts",
    "api:watch": "tsx scripts/generate-api.ts --watch",
    "api:proto:lint": "npx -y @bufbuild/buf lint api",
    "api:proto:gen": "npx -y @bufbuild/buf generate api --template api/buf.gen.yaml && node scripts/generate-proto-route-manifest.mjs",
    "api:proto:check": "npm run api:proto:lint && npm run api:proto:gen",
    "dev": "npm run api:proto:gen && ./scripts/start-selected-expo.sh",
    "local:init": "./scripts/dev/init-app.sh",
    "local:proxy": "node scripts/dev/reverse-proxy.mjs",
    "config:init": "node tools/config-manager/manager.mjs init",
    "config:reset": "node tools/config-manager/manager.mjs reset",
    "config:migrate:group": "node tools/config-manager/manager.mjs migrate-group",
    "config:set": "node tools/config-manager/manager.mjs set",
    "config:get": "node tools/config-manager/manager.mjs get",
    "config:list": "node tools/config-manager/manager.mjs list",
    "config:delete": "node tools/config-manager/manager.mjs delete",
    "config:seed": "node tools/config-manager/manager.mjs seed",
    "scaffold": "node tools/scaffold/cli.mjs",
    "scaffold:init": "node tools/scaffold/cli.mjs init",
    "scaffold:feature": "node tools/scaffold/cli.mjs feature",
    "studio:scan": "node scripts/generate-repo-scan.mjs",
    "ui:scan": "node scripts/scan-ui-documents.mjs",
    "config:firebase:set": "./scripts/dev/set-firebase-config.sh",
    "visualize": "node tools/code-visualizer/server.mjs"
  },
  "dependencies": {
    "@tamagui/babel-plugin": "^2.3.0",
    "@tamagui/config": "^2.3.0",
    "@tamagui/core": "^2.3.0",
    "@bufbuild/protobuf": "^2.12.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "better-sqlite3": "^12.10.0",
    "expo": "~54.0.33",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "firebase": "^10.14.1",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-refresh": "^0.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "babel-preset-expo": "~54.0.4",
    "chokidar-cli": "^3.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "http-proxy": "^1.18.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.14",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "^19.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  }
}
