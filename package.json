{
  "name": "@appforge/platform",
  "version": "0.4.1",
  "description": "Shared UI, features, and API layer for AppForge-scaffolded apps.",
  "files": [
    "src/config/**/*.ts",
    "src/generated/**/*",
    "src/platform/**/*.ts",
    "src/platform/**/*.tsx",
    "src/features/auth/**/*.ts",
    "src/features/auth/**/*.tsx",
    "src/features/entitlements/**/*.ts",
    "src/features/entitlements/**/*.tsx",
    "src/features/serverless-entitlement/**/*.ts",
    "src/features/serverless-entitlement/**/*.tsx",
    "src/features/login/**/*.ts",
    "src/features/login/**/*.tsx",
    "src/features/register/**/*.ts",
    "src/features/register/**/*.tsx",
    "src/features/settings/**/*.ts",
    "src/features/settings/**/*.tsx",
    "src/types/**/*.d.ts",
    "!**/AGENTS.md",
    "!**/README.md",
    "!**/docs/**",
    "!**/__tests__/**",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.test.d.ts",
    "!**/.gitkeep",
    "!**/.DS_Store",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    "./core": "./src/platform/core/index.ts",
    "./ui": "./src/platform/ui/index.ts",
    "./theme": "./src/platform/ui/theme/index.ts",
    "./providers": "./src/platform/providers/index.ts",
    "./workspace": "./src/platform/workspace/index.ts",
    "./navigation": "./src/platform/navigation/index.ts",
    "./api": "./src/platform/api/index.ts",
    "./features/auth": "./src/features/auth/index.ts",
    "./features/login": "./src/features/login/index.ts",
    "./features/register": "./src/features/register/index.ts",
    "./features/serverless-entitlement": "./src/features/serverless-entitlement/index.ts",
    "./features/settings": "./src/features/settings/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "contracts:validate": "node --import tsx scripts/contract-system.ts validate",
    "contracts:analyze": "node --import tsx scripts/contract-system.ts analyze",
    "contracts:task": "node --import tsx scripts/contract-system.ts task",
    "contracts:drift": "node --import tsx scripts/contract-system.ts drift",
    "contracts:migrate": "node --import tsx scripts/migrate-feature-contracts.ts",
    "test:public-api-smoke": "cd smoke/public-api-consumer && npm install --no-fund --no-audit && ./node_modules/.bin/tsc --noEmit",
    "test:contracts": "jest --watchman=false --runTestsByPath src/agent/contracts/__tests__/system.test.ts",
    "lint:ui": "node scripts/lint-ui-stamps.mjs",
    "test": "jest --watchman=false",
    "test:usecases": "jest --watchman=false --testPathPattern=\"src/features/.*/usecases/__tests__/.*\\.test\\.ts$\"",
    "test:viewmodel": "jest --watchman=false --testPathPattern=\"src/features/.*/viewmodel/__tests__/.*\\.test\\.ts$\"",
    "test:controllers": "jest --watchman=false --testPathPattern=\"src/features/.*/__tests__/.*controller.*\\.test\\.ts$\"",
    "test:coverage": "jest --coverage",
    "api:generate": "tsx scripts/generate-api.ts",
    "api:proto:lint": "npx -y @bufbuild/buf lint api",
    "api:proto:gen": "npx -y @bufbuild/buf generate api --template api/buf.gen.yaml && node scripts/generate-proto-route-manifest.mjs",
    "api:proto:check": "npm run api:proto:lint && npm run api:proto:gen"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@tamagui/babel-plugin": "^2.3.0",
    "@tamagui/config": "^2.3.0",
    "@tamagui/core": "^2.3.0",
    "firebase": "^10.14.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "@react-navigation/native": "*",
    "expo": "*",
    "expo-av": "*",
    "expo-constants": "*",
    "expo-font": "*",
    "expo-linking": "*",
    "expo-router": "*",
    "expo-status-bar": "*",
    "expo-system-ui": "*",
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-safe-area-context": "*",
    "react-native-screens": "*",
    "react-native-svg": "*",
    "react-native-web": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "babel-preset-expo": "~54.0.4",
    "chokidar-cli": "^3.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "http-proxy": "^1.18.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.14",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "^19.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  }
}
